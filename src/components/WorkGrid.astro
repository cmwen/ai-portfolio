---
import WorkCard from './WorkCard.astro';
import type { Work } from '../lib/works';

interface Props {
  works: Work[];
}

const { works } = Astro.props;
---

{
  works.length > 0 ? (
    <section
      class="grid gap-x-5 gap-y-12 sm:grid-cols-2 lg:grid-cols-3"
      aria-label="Works gallery"
    >
      {works.map((work, index) => (
        <WorkCard work={work} priority={index < 3} />
      ))}
    </section>
  ) : (
    <p class="rounded-lg border border-[var(--line)] bg-[var(--surface)] p-6 text-[var(--muted)]">
      No published works in this section yet.
    </p>
  )
}
