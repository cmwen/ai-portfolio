---
import { site, withBase } from '../lib/site';

const currentPath = Astro.url.pathname;
---

<header
  class="sticky top-0 z-20 border-b border-[var(--line)] bg-[color-mix(in_srgb,var(--bg)_86%,transparent)] backdrop-blur"
>
  <nav
    class="mx-auto flex max-w-7xl items-center justify-between gap-5 px-5 py-4 lg:px-8"
    aria-label="Primary"
  >
    <a
      class="focus-ring flex min-w-fit items-center gap-3 rounded"
      href={withBase('/')}
    >
      <span
        class="grid size-9 place-items-center rounded-full border border-[var(--line)] bg-[var(--surface)] text-sm font-semibold"
      >
        MW
      </span>
      <span class="text-sm font-semibold uppercase tracking-[0.18em]">
        AI Portfolio
      </span>
    </a>
    <div class="flex gap-1 overflow-x-auto text-sm text-[var(--muted)]">
      {
        site.nav.map((item) => {
          const href = withBase(item.href);
          const isExternal = /^(https?:)?\/\//.test(item.href);
          const isActive =
            !isExternal && item.href === '/'
              ? currentPath === import.meta.env.BASE_URL
              : !isExternal && currentPath.startsWith(href);

          return (
            <a
              class:list={[
                'focus-ring rounded-full px-3 py-2 transition hover:bg-[var(--surface)] hover:text-[var(--ink)]',
                isActive && 'bg-[var(--surface)] text-[var(--ink)] shadow-sm',
              ]}
              href={href}
              aria-current={isActive ? 'page' : undefined}
            >
              {item.label}
            </a>
          );
        })
      }
    </div>
  </nav>
</header>
