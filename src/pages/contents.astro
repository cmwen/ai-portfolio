---
import PageHeader from '../components/PageHeader.astro';
import WorkGrid from '../components/WorkGrid.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getWorksByPage } from '../lib/works';

const works = await getWorksByPage('content');
---

<BaseLayout
  title="Contents"
  description="AI-assisted posters, comics, videos, audio, and embed-ready content."
>
  <PageHeader
    eyebrow="Contents"
    title="Posters, comics, video, and media pieces."
    description="Generated content outputs that are meant to be watched, read, heard, shared, or embedded."
  />
  <section class="mx-auto max-w-7xl px-5 pb-20 lg:px-8">
    <WorkGrid works={works} />
  </section>
</BaseLayout>
