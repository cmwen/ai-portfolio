---
import { render } from 'astro:content';
import MediaRenderer from '../../components/MediaRenderer.astro';
import WorkMeta from '../../components/WorkMeta.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  getAllWorks,
  labelForCategory,
  labelForPage,
  type Work,
} from '../../lib/works';

export async function getStaticPaths() {
  const works = await getAllWorks();
  return works.map((work) => ({
    params: { slug: work.data.slug },
    props: { work },
  }));
}

interface Props {
  work: Work;
}

const { work } = Astro.props;
const { Content } = await render(work);
---

<BaseLayout
  title={work.data.title}
  description={work.data.description}
  image={work.data.thumbnail}
>
  <article class="mx-auto max-w-7xl px-5 py-12 lg:px-8 lg:py-16">
    <header class="mb-10 max-w-4xl">
      <p
        class="text-sm font-semibold uppercase tracking-[0.22em] text-[var(--accent-ink)]"
      >
        {labelForPage(work.data.page)} / {labelForCategory(work.data.category)}
      </p>
      <h1 class="mt-4 text-4xl font-semibold leading-none md:text-6xl">
        {work.data.title}
      </h1>
      <p class="mt-6 text-lg leading-8 text-[var(--muted)]">
        {work.data.description}
      </p>
    </header>

    <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_20rem]">
      <div class="space-y-10">
        <MediaRenderer work={work} />
        <div class="prose-lab max-w-3xl">
          <Content />
        </div>
        {
          work.data.prompts.length > 0 && (
            <section class="max-w-3xl rounded-lg border border-[var(--line)] bg-[var(--surface)] p-5">
              <h2 class="text-xl font-semibold">Prompt notes</h2>
              <ul class="mt-4 space-y-3 text-sm leading-7 text-[var(--muted)]">
                {work.data.prompts.map((prompt) => (
                  <li>{prompt}</li>
                ))}
              </ul>
            </section>
          )
        }
      </div>
      <WorkMeta work={work} />
    </div>
  </article>
</BaseLayout>
