---
import PageHeader from '../../components/PageHeader.astro';
import WorkGrid from '../../components/WorkGrid.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllWorks } from '../../lib/works';

const works = await getAllWorks();
---

<BaseLayout title="Works" description="All published AI portfolio works.">
  <PageHeader
    eyebrow="Gallery"
    title="All AI-built records."
    description="A running archive of generated images, media experiments, design studies, and small side projects."
  />
  <section class="mx-auto max-w-7xl px-5 pb-20 lg:px-8">
    <WorkGrid works={works} />
  </section>
</BaseLayout>
