---
import PageHeader from '../components/PageHeader.astro';
import WorkGrid from '../components/WorkGrid.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getWorksByType } from '../lib/works';

const works = await getWorksByType(['image']);
---

<BaseLayout title="Images" description="AI image works and visual studies.">
  <PageHeader
    eyebrow="Images"
    title="AI image records."
    description="Generated images and visual studies. New files can start as simple drops in incoming/images and grow into richer notes later."
  />
  <section class="mx-auto max-w-7xl px-5 pb-20 lg:px-8">
    <WorkGrid works={works} />
  </section>
</BaseLayout>
