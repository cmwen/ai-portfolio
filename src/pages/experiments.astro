---
import PageHeader from '../components/PageHeader.astro';
import WorkGrid from '../components/WorkGrid.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getWorksByType } from '../lib/works';

const works = await getWorksByType(['collection']);
---

<BaseLayout
  title="Experiments"
  description="AI design experiments and collections."
>
  <PageHeader
    eyebrow="Experiments"
    title="Collections and process experiments."
    description="Design systems, material studies, logo explorations, and multi-image research threads."
  />
  <section class="mx-auto max-w-7xl px-5 pb-20 lg:px-8">
    <WorkGrid works={works} />
  </section>
</BaseLayout>
