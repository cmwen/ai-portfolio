---
import PageHeader from '../components/PageHeader.astro';
import WorkGrid from '../components/WorkGrid.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/site';
import { getFeaturedWorks } from '../lib/works';

const featuredWorks = await getFeaturedWorks();
---

<BaseLayout>
  <section
    class="mx-auto grid max-w-7xl items-end gap-10 px-5 py-14 lg:grid-cols-[1.05fr_0.95fr] lg:px-8 lg:py-20"
  >
    <div>
      <p
        class="text-sm font-semibold uppercase tracking-[0.22em] text-[var(--accent-ink)]"
      >
        Min Wen's AI collection
      </p>
      <h1 class="mt-5 text-5xl font-semibold leading-none md:text-7xl">
        AI designs and AI content, kept in two clean shelves.
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-[var(--muted)]">
        Designs are visual/UI artifacts like icons, image studies, UX concepts,
        and systems. Contents are media outputs like posters, comics, video,
        audio, and embeds.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a
          class="focus-ring rounded-full bg-[var(--ink)] px-5 py-3 text-sm font-semibold text-[var(--bg)]"
          href={withBase('/designs/')}
        >
          View designs
        </a>
        <a
          class="focus-ring rounded-full border border-[var(--line)] bg-[var(--surface)] px-5 py-3 text-sm font-semibold"
          href={withBase('/contents/')}
        >
          View contents
        </a>
      </div>
    </div>
    <div class="relative">
      <img
        class="aspect-[4/5] w-full rounded-lg border border-[var(--line)] object-cover shadow-2xl"
        src={withBase('/media/images/latent-harbor.webp')}
        alt="Placeholder AI portfolio hero image showing an atmospheric creative study."
        loading="eager"
        decoding="async"
      />
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-5 pb-16 lg:px-8 lg:pb-24">
    <div
      class="mb-8 flex flex-col justify-between gap-4 md:flex-row md:items-end"
    >
      <div>
        <p
          class="text-sm font-semibold uppercase tracking-[0.22em] text-[var(--accent-ink)]"
        >
          Latest records
        </p>
        <h2 class="mt-3 text-3xl font-semibold md:text-4xl">
          Selected AI artifacts
        </h2>
      </div>
      <a
        class="focus-ring rounded-full border border-[var(--line)] px-4 py-2 text-sm font-medium hover:border-[var(--accent)]"
        href={withBase('/works/')}
      >
        Browse all
      </a>
    </div>
    <WorkGrid works={featuredWorks} />
  </section>

  <PageHeader
    eyebrow="Low-friction workflow"
    title="Upload once, route it to the right shelf."
    description="The upload page records the destination page, content category, AI tool, tags, and optional YouTube URL. The build script turns that into optimized media, thumbnails, embeds, and MDX records."
  />
</BaseLayout>
