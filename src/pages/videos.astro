---
import PageHeader from '../components/PageHeader.astro';
import WorkGrid from '../components/WorkGrid.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getWorksByType } from '../lib/works';

const works = await getWorksByType(['video', 'embed']);
---

<BaseLayout title="Videos" description="AI video studies and safe embeds.">
  <PageHeader
    eyebrow="Videos"
    title="Video and embed records."
    description="Legacy video filter. New browsing starts from Contents."
  />
  <section class="mx-auto max-w-7xl px-5 pb-20 lg:px-8">
    <WorkGrid works={works} />
  </section>
</BaseLayout>
