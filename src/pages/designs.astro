---
import PageHeader from '../components/PageHeader.astro';
import WorkGrid from '../components/WorkGrid.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getWorksByPage } from '../lib/works';

const works = await getWorksByPage('design');
---

<BaseLayout
  title="Designs"
  description="AI-assisted icons, images, UX explorations, identity studies, and visual systems."
>
  <PageHeader
    eyebrow="Designs"
    title="Icons, images, UX, and visual systems."
    description="A compact collection of AI-assisted design artifacts grouped by what they are, not by a written story around them."
  />
  <section class="mx-auto max-w-7xl px-5 pb-20 lg:px-8">
    <WorkGrid works={works} />
  </section>
</BaseLayout>
